# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:port/skillpack
SYNC_DATABASE_URL=postgresql://user:password@host:port/skillpack

# Cache
REDIS_URL=redis://localhost:6379/0

# AI - Groq (primary, free)
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# AI - NVIDIA NIM (fallback, free credits)
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-405b-instruct

# GitHub (get free token at github.com/settings/tokens)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_TOKEN_2=optional_second_token_for_higher_rate_limits

# Skills.sh
SKILLS_SH_BASE_URL=https://skills.sh

# App
APP_ENV=development
LOG_LEVEL=INFO
